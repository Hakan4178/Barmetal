#!/usr/bin/expect -f
set timeout 30
spawn virsh -c qemu:///system console archlinux
expect "Connected to domain"
send "\r"
expect "#"
send "cd /mnt/kod\r"
expect "#"
send "gcc test_hugepage.c -o test_hugepage\r"
expect "#"
send "./test_hugepage > output.txt &\r"
expect "#"
send "PID=\$!\r"
expect "#"
send "echo 1 > /proc/svm_dump/full_dump\r"
expect "#"
send "sleep 2\r"
expect "#"
send "bash tools/monitor_proc.sh --snap \$PID\r"
expect "#"
send "cat /proc/svm_dump/output > snapshot_huge.bin\r"
expect "#"
send "kill \$PID\r"
expect "#"
send "exit\r"
